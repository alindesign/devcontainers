{
  "name": "Node.js + Claude (alindesign)",
  "image": "ghcr.io/alindesign/devcontainer-base:latest",
  "features": {
    "ghcr.io/alindesign/features/claude:1": {},
    "ghcr.io/alindesign/features/node:2": {
      "version": "lts",
      "packageManager": "pnpm"
    }
  },
  "remoteUser": "vscode",
  "initializeCommand": "sh -c '[ \"$(uname)\" != Darwin ] || { mkdir -p \"$HOME/.claude\" && security find-generic-password -s \"Claude Code-credentials\" -w 2>/dev/null > \"$HOME/.claude/.credentials.json\" && chmod 600 \"$HOME/.claude/.credentials.json\"; } || true'",
  "mounts": [
    { "source": "${localEnv:HOME}/.ssh", "target": "/home/vscode/.ssh", "type": "bind" },
    { "source": "${localEnv:HOME}/.gnupg", "target": "/home/vscode/.gnupg", "type": "bind" },
    { "source": "${localEnv:HOME}/.claude", "target": "/home/vscode/.claude", "type": "bind" },
    { "source": "${localEnv:HOME}/.claude.json", "target": "/home/vscode/.claude.json", "type": "bind" }
  ],
  "postCreateCommand": "node --version && pnpm --version",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  }
}
