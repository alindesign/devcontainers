.DS_Store
*.swp
*.swo
node_modules/
.idea/
.vscode/
.claude/
*.log

# Per-project lockfiles regenerated by `devcontainer up`; keep out of git.
examples/*/.devcontainer/devcontainer-lock.json

# Negate global gitignore `secrets` pattern so our secrets feature lives in
# the repo. (We don't ship actual secrets here; the feature name is fine.)
!src/secrets/
!src/secrets/**
!test/secrets/
!test/secrets/**
