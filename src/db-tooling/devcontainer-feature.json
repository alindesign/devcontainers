{
  "id": "db-tooling",
  "version": "1.0.1",
  "name": "Database CLI tooling",
  "description": "psql + mysql + redis-cli + mongosh. Each can be skipped via the skipX options. Connects to external databases — no servers are installed.",
  "documentationURL": "https://github.com/alindesign/devcontainers/tree/main/src/db-tooling",
  "options": {
    "skipPostgres": {
      "type": "boolean",
      "default": false,
      "description": "Skip postgresql-client (psql, pg_dump, …)."
    },
    "skipMysql": {
      "type": "boolean",
      "default": false,
      "description": "Skip default-mysql-client (mysql, mysqldump, …)."
    },
    "skipRedis": {
      "type": "boolean",
      "default": false,
      "description": "Skip redis-tools (redis-cli, redis-benchmark)."
    },
    "skipMongosh": {
      "type": "boolean",
      "default": false,
      "description": "Skip mongosh (MongoDB shell). Installed from MongoDB's official apt repo."
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}
