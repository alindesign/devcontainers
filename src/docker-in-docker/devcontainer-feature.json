{
  "id": "docker-in-docker",
  "version": "1.0.0",
  "name": "Docker-in-Docker",
  "description": "Installs Docker Engine + buildx + compose v2 inside the container. The Docker daemon starts via /usr/local/share/docker-init.sh on container creation.",
  "documentationURL": "https://github.com/alindesign/devcontainers/tree/main/src/docker-in-docker",
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "Docker Engine version. 'latest' tracks the upstream stable channel."
    },
    "installBuildx": {
      "type": "boolean",
      "default": true,
      "description": "Install docker-buildx-plugin."
    },
    "installCompose": {
      "type": "boolean",
      "default": true,
      "description": "Install docker-compose-plugin (Compose v2)."
    },
    "dockerDashComposeVersion": {
      "type": "string",
      "default": "v2",
      "enum": ["v2", "none"],
      "description": "Whether to install the legacy `docker-compose` Python shim alongside Compose v2."
    }
  },
  "entrypoint": "/usr/local/share/docker-init.sh",
  "init": true,
  "privileged": true,
  "containerEnv": {
    "DOCKER_BUILDKIT": "1"
  },
  "mounts": [
    {
      "source": "dind-var-lib-docker-${devcontainerId}",
      "target": "/var/lib/docker",
      "type": "volume"
    }
  ],
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}
