{
  "name": "Data Science (alindesign)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/alindesign/features/dotfiles:1": {
      "gitUserName": "${templateOption:gitUserName}",
      "gitUserEmail": "${templateOption:gitUserEmail}"
    },
    "ghcr.io/alindesign/features/python:1": {
      "version": "${templateOption:pythonVersion}",
      "packageManager": "uv"
    },
    "ghcr.io/alindesign/features/db-tooling:1": {
      "skipMongosh": true
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "uv tool install --force jupyterlab && uv tool install --force duckdb && jupyter --version | head -n1 && duckdb --version",
  "forwardPorts": [8888],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff",
        "tomoki1207.pdf"
      ]
    }
  }
}
