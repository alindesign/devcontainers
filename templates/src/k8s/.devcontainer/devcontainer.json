{
  "name": "Kubernetes (alindesign)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/alindesign/features/dotfiles:1": {
      "gitUserName": "${templateOption:gitUserName}",
      "gitUserEmail": "${templateOption:gitUserEmail}"
    },
    "ghcr.io/alindesign/features/go:1": {
      "version": "${templateOption:goVersion}"
    },
    "ghcr.io/alindesign/features/kubectl:1": {
      "kubectlVersion": "${templateOption:kubectlVersion}"
    },
    "ghcr.io/alindesign/features/docker-in-docker:1": {}
  },
  "remoteUser": "vscode",
  "mounts": [
    { "source": "${localEnv:HOME}/.kube", "target": "/home/vscode/.kube", "type": "bind" }
  ],
  "overrideCommand": false,
  "postCreateCommand": "kubectl version --client=true | head -n1 && helm version --short && go version",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "golang.go",
        "redhat.vscode-yaml"
      ]
    }
  }
}
